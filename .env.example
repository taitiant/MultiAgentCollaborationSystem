# Docker base images
# 默认使用 Docker Hub 代理镜像，避免直接拉取 docker.io 时出现 TLS handshake timeout / 429。
PYTHON_BASE_IMAGE=docker.m.daocloud.io/library/python:3.11-slim
NGINX_IMAGE=docker.m.daocloud.io/library/nginx:1.25-alpine
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine

# PostgreSQL defaults for Docker Compose
POSTGRES_DB=macs
POSTGRES_USER=macs
POSTGRES_PASSWORD=macs

# Optional Python package mirrors during image build
# 如需加速 pip 安装，可取消注释并按需调整。
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_EXTRA_INDEX_URL=

# Runtime API keys (fill locally if needed)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# CODEX_API_KEY=
